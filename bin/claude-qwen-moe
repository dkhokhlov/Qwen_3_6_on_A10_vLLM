#!/usr/bin/env bash
# Wrap the `claude` CLI to drive local Qwen3.6-35B-A3B (MoE, via the LiteLLM sole
# proxy) as if it were Anthropic. All knobs are env-only; this sets them and
# execs `claude`.
#
# Stack  = which wrapper: this one targets the 35B MoE stack (make start35);
#          claude-qwen targets the 27B dense stack (make start).
# Flavor = QWEN_FLAVOR (default | preserve | nothink); empty/default = strip.
#          Switch mid-session with /model qwen3.6-35b-a3b[-preserve|-nothink].
# ANTHROPIC_SMALL_FAST_MODEL is always the -nothink variant (bg tasks never reason).
#
# The proxy runs auth-free and is bound 0.0.0.0:4000 (LAN-accessible), so the
# token below is a placeholder -- Claude Code merely requires ANTHROPIC_AUTH_TOKEN
# to be non-empty. Edit the placeholder here if you re-enable LiteLLM auth.
#
# Values are FORCED, not defaulted. A host whose `claude` is gated through a
# third-party Anthropic gateway (e.g. api.z.ai) already exports ANTHROPIC_BASE_URL
# and ANTHROPIC_MODEL; `${VAR:-default}` would let those leak through and send
# traffic to the wrong endpoint/model. CLAUDE_QWEN_BASE_URL is the one escape
# hatch -- set it to drive a remote box running this proxy instead of localhost.
set -euo pipefail

BASE="qwen3.6-35b-a3b"                   # MoE; claude-qwen uses qwen3.6-27b
case "${QWEN_FLAVOR:-default}" in
  default)  FLAVOR="" ;;
  preserve) FLAVOR="-preserve" ;;
  nothink)  FLAVOR="-nothink" ;;
  *) echo "QWEN_FLAVOR must be one of: default, preserve, nothink" >&2; exit 1 ;;
esac

export ANTHROPIC_BASE_URL="${CLAUDE_QWEN_BASE_URL:-http://localhost:4000}"   # NO /v1
export ANTHROPIC_AUTH_TOKEN="sk-claude-qwen-local"                           # placeholder (auth off)
export ANTHROPIC_MODEL="$BASE$FLAVOR"                                        # default = strip
export ANTHROPIC_SMALL_FAST_MODEL="$BASE-nothink"                           # bg: no reasoning
export CLAUDE_MODEL="$BASE$FLAVOR"   # /home/owner/bin/claude reads this -> --model

# Let the /model picker list all three flavors; cut telemetry noise.
export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Auth-token path is mutually exclusive with the raw API key / cloud gateways.
unset ANTHROPIC_API_KEY CLAUDE_CODE_USE_BEDROCK CLAUDE_CODE_USE_VERTEX
# Defeat alias remap a third-party-gateway host may export (e.g. ANTHROPIC_DEFAULT_SONNET_MODEL=glm-*),
# which would otherwise re-point /model sonnet|opus|haiku away from our models.
unset ANTHROPIC_DEFAULT_SONNET_MODEL ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_HAIKU_MODEL

exec claude "$@"
