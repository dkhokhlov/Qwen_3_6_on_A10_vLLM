#!/usr/bin/env bash
# 2xA10 TP=2 variant of opencode-qwen: lifts the context window to 256k (and the output cap
# to dense 16k / moe 32k) by exporting QWEN_CTX_MODE=2x and delegating to opencode-qwen. Use
# this against the TP=2 stacks (make start-tp2 / make start35-tp2); use opencode-qwen (the
# single-A10 default) against the 1x stacks. Same --model / QWEN_FLAVOR knobs as
# opencode-qwen; see that script for full documentation.
export QWEN_CTX_MODE=2x
exec opencode-qwen "$@"
