#!/usr/bin/env bash
# Wrap the `claude` CLI to drive a local Qwen3.6 line (via the LiteLLM sole proxy)
# as if it were Anthropic. All knobs are env-only EXCEPT --model; this sets them
# and execs `claude`.
#
# Model   = --model {moe|dense} (default moe). MUST match the running stack:
#             moe   -> qwen3.6-35b-a3b  (make start35)
#             dense -> qwen3.6-27b      (make start)
#           One A10 + one host :4000 -> only one stack runs at a time, so switching
#           lines is a manual cold swap (make stop/start35), NOT automatic. This
#           wrapper does NOT start the stack -- run the matching `make` target first.
# Flavor  = QWEN_FLAVOR (default | preserve | nothink); empty/default = strip.
#           Switch mid-session with /model qwen3.6-<line>[-preserve|-nothink].
# ANTHROPIC_SMALL_FAST_MODEL is always the -nothink variant (bg tasks never reason).
#
# The proxy runs auth-free and is bound 0.0.0.0:4000 (LAN-accessible), so the
# token below is a placeholder -- Claude Code merely requires ANTHROPIC_AUTH_TOKEN
# to be non-empty. Edit the placeholder here if you re-enable LiteLLM auth.
#
# Values are FORCED, not defaulted. A host whose `claude` is gated through a
# third-party Anthropic gateway (e.g. api.z.ai) already exports ANTHROPIC_BASE_URL
# and ANTHROPIC_MODEL; `${VAR:-default}` would let those leak through and send
# traffic to the wrong endpoint/model. CLAUDE_QWEN_BASE_URL is the one escape
# hatch -- set it to drive a remote box running this proxy instead of localhost.
set -euo pipefail

MODEL="moe"                               # --model {moe|dense}; moe is the default
rest=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)    MODEL="${2:?claude-qwen: --model needs a value}"; shift 2 ;;
    --model=*)  MODEL="${1#--model=}"; shift ;;
    *)          rest+=("$1"); shift ;;
  esac
done

case "$MODEL" in
  moe)   BASE="qwen3.6-35b-a3b"; CTX_WINDOW=128000; MAX_OUTPUT=16384 ;;
  dense) BASE="qwen3.6-27b";     CTX_WINDOW=64000;  MAX_OUTPUT=8192  ;;
  *) echo "claude-qwen: --model must be 'moe' or 'dense' (got '$MODEL')" >&2; exit 2 ;;
esac

case "${QWEN_FLAVOR:-default}" in
  default)  FLAVOR="" ;;
  preserve) FLAVOR="-preserve" ;;
  nothink)  FLAVOR="-nothink" ;;
  *) echo "QWEN_FLAVOR must be one of: default, preserve, nothink" >&2; exit 1 ;;
esac

export ANTHROPIC_BASE_URL="${CLAUDE_QWEN_BASE_URL:-http://localhost:4000}"   # NO /v1
export ANTHROPIC_AUTH_TOKEN="sk-claude-qwen-local"                           # placeholder (auth off)
export ANTHROPIC_MODEL="$BASE$FLAVOR"                                        # default = strip
export ANTHROPIC_SMALL_FAST_MODEL="$BASE-nothink"                            # bg: no reasoning
export CLAUDE_MODEL="$BASE$FLAVOR"   # the 'claude' on PATH reads this -> --model
export CLAUDE_CODE_SUBAGENT_MODEL="$BASE-nothink"

# Claude Code's gateway model discovery reads only id/display_name from /v1/models,
# never token limits, so behind this proxy it assumes a 200k window AND sends its
# built-in max_tokens=32000 default. Both break the real upstream (--max-model-len):
# compaction is calibrated to 200k -> fires at 160k, PAST the 128k/64k wall, so input
# grows unchecked until it overflows; and 32000 + a large prompt overflows directly.
# Tell it the real window and cap output so compaction triggers at 80% of the actual
# window. The LiteLLM deployment-hook clamp (litellm_callbacks.py, env
# CLAUDE_QWEN_MAX_TOKENS_CAP) is the backstop for subagents + the small/fast model,
# which ignore CLAUDE_CODE_MAX_OUTPUT_TOKENS (claude-code issue #25569). PCT is 80
# (settings.json); the cap must satisfy PCT*WINDOW + cap <= WINDOW -> cap <= WINDOW/5.
export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$CTX_WINDOW"
export CLAUDE_CODE_MAX_OUTPUT_TOKENS="$MAX_OUTPUT"

# Let the /model picker list all three flavors; cut telemetry noise.
export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Auth-token path is mutually exclusive with the raw API key / cloud gateways.
unset ANTHROPIC_API_KEY CLAUDE_CODE_USE_BEDROCK CLAUDE_CODE_USE_VERTEX
# Defeat alias remap a third-party-gateway host may export (e.g. ANTHROPIC_DEFAULT_SONNET_MODEL=glm-*),
# which would otherwise re-point /model sonnet|opus|haiku away from our models.
unset ANTHROPIC_DEFAULT_SONNET_MODEL ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_HAIKU_MODEL

# Disable claude.ai connectors ONLY in this wrapper session; also silences the
# "claude.ai connectors are disabled because ANTHROPIC_API_KEY..." warning.
# Value MUST be a falsy sentinel ("false"/"0"/"off") — "true"/"1" re-enables.
export ENABLE_CLAUDEAI_MCP_SERVERS="false"

# Web search is handled SERVER-SIDE, not in this wrapper: LiteLLM's
# websearch_interception callback converts claude's native web_search tool to
# litellm_web_search, runs it via SearXNG (DuckDuckGo), and Qwen synthesizes a
# grounded answer -- so plain `claude` with these Qwen env vars is all that's
# needed (no client-side MCP, no --disallowedTools). See litellm_config.yaml
# (callbacks + search_tools) + the searxng compose service.
exec claude "${rest[@]}"
