{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/claude-sonnet",
  "small_model": "litellm/claude-haiku",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM (local Qwen3.6)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "dummy"
      },
      "models": {
        "claude-sonnet": {
          "name": "Qwen3.6 27B (strip thinking)",
          "tool_call": true,
          "limit": { "context": 64000, "output": 8192 }
        },
        "claude-sonnet-preserve": {
          "name": "Qwen3.6 27B (preserve thinking)",
          "tool_call": true,
          "limit": { "context": 64000, "output": 8192 }
        },
        "claude-haiku": {
          "name": "Qwen3.6 27B (no reasoning)",
          "tool_call": true,
          "limit": { "context": 64000, "output": 4096 }
        }
      }
    }
  }
}
